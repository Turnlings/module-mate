- cache [current_user] do  
  .stats-container 
    .stat 
      .stat-header 
        = link_to user_path(current_user) do
          Study Streak
      = turbo_frame_tag "dashboard_study_streak" do
        .stat-content
          = current_user.study_streak
          .label= "#{'day'.pluralize(current_user.study_streak)}"
    .stat 
      .stat-header Minutes Today
      = turbo_frame_tag "dashboard_minutes_today" do
        .stat-content= current_user.minutes_today
    .stat 
      .stat-header Achieved Score
      .stat-content= number_to_percentage(current_user.achieved_score, precision: 2)
    .stat 
      .stat-header Predicted
      .stat-content= number_to_percentage(current_user.predicted_score, precision: 2)