-# Stats
= render partial: 'shared/dashboard_stats'

-# Graph on left
= turbo_frame_tag "dashboard_time_chart" do
  = render partial: 'shared/time_chart', locals: { subject: current_user, time_path: -> { time_dashboard_path(cumulative: params[:cumulative], date_since: params[:date_since]) }, date_since: params[:date_since], form_url: dashboard_path, turbo_frame_id: "dashboard_time_chart" }

-# Years
= turbo_frame_tag "years" do
  .gt-empty-card
    .heading
      %h2 Years

      = link_to new_year_path, class: 'icon-button light', title: 'Add New Year' do
        %i.fa-solid.fa-plus
        %span Add
    .body
      .link-cards-list
        - @years.each do |year|
          = render partial: 'shared/year_card', locals: { year: year }