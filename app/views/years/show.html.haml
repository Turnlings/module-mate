.page-heading
  %nav
    %ol.breadcrumb
      %li.breadcrumb-item.active= @year.name
  .right-button.button-row
    = link_to edit_year_path(@year), class: 'icon-button' do
      %i.fa-solid.fa-pen-to-square
      %span Edit

-# Stats
.stats-container 
  .stat 
    .stat-header Credits
    .stat-content= number_with_precision(@year.credits, precision: 0)
  .stat 
    .stat-header Average Score
    .stat-content= number_with_precision(@year.average_score(current_user), precision: 2) + '%'
  .stat 
    .stat-header
      = link_to edit_year_path(@year, anchor: 'final_score') do
        Achieved Score
    .stat-content= number_with_precision(@year.achieved_score(current_user), precision: 2) + '%'

= turbo_frame_tag "semesters" do
  .gt-empty-card
    .heading
      %h3 Semesters

      = link_to new_semester_path(year_id: @year.id), class: 'icon-button light' do
        %i.fa-solid.fa-plus
        %span Add
    .body
      .link-cards-list
        - @year.semesters.each do |semester|
          = render partial: 'shared/semester_card', locals: { semester: semester }

-# Graph
= turbo_frame_tag "year_time_chart" do
  = render partial: 'shared/time_chart', locals: { subject: @year, time_path: -> { time_year_path(id: @year.id, cumulative: params[:cumulative], date_since: params[:date_since]) }, date_since: params[:date_since], form_url: year_path(@year), turbo_frame_id: "year_time_chart" }